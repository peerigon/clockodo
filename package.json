    "test:types": "tsc",
    "test:unit": "vitest --run",
    "vitest": "vitest"
  },
  "dependencies": {
    "env-var": "^7.5.0"
  },
  "devDependencies": {
    "@djankies/vitest-mcp": "0.5.1",
    "@eslint/mcp": "0.3.7",
    "@peerigon/configs": "^18.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^9.0.2",
    "pin-github-action": "^3.4.0",
    "prettier": "^3.8.4",
    "secretlint": "^13.0.2",
    "ts-lsp-mcp": "0.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "error"
    }
  }
