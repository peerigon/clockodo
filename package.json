{
  "name": "@peerigon/template",
  "version": "1.0.0",
  "description": "Boilerplate template to kick start new projects at Peerigon",
  "keywords": [],
  "license": "MIT License",
  "author": "hello@peerigon.com",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "test": "run-p test:*",
